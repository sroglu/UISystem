/*
 * showcase.uss — Base layout classes for UISystem demo/showcase scenes
 * Use with: typography.uss + light.uss (or dark.uss)
 *
 * Structure pattern:
 *   .showcase-root
 *     └── ui:ScrollView.showcase-scroll
 *           └── .showcase-content
 *                 ├── Label.showcase-page-title
 *                 └── .showcase-section (repeated)
 *                       ├── Label.showcase-section__title
 *                       └── .showcase-row
 */

/* ------------------------------------------------------------------ */
/*  Root container — fills the entire panel                            */
/* ------------------------------------------------------------------ */
.showcase-root {
    flex-direction: column;
    width: 100%;
    height: 100%;
    background-color: var(--m3-background, rgb(255, 251, 254));
}

/* ------------------------------------------------------------------ */
/*  ScrollView — fills remaining space, transparent background         */
/* ------------------------------------------------------------------ */
.showcase-scroll {
    flex-grow: 1;
    background-color: rgba(0, 0, 0, 0);
}

/* ------------------------------------------------------------------ */
/*  Content area inside the ScrollView                                 */
/* ------------------------------------------------------------------ */
.showcase-content {
    width: 100%;
    flex-direction: column;
    padding: 24px;
}

/* ------------------------------------------------------------------ */
/*  Page title                                                          */
/* ------------------------------------------------------------------ */
.showcase-page-title {
    color: var(--m3-on-background, rgb(28, 27, 31));
    margin-bottom: 24px;
}

/* ------------------------------------------------------------------ */
/*  Section wrapper (title + row of components)                        */
/* ------------------------------------------------------------------ */
.showcase-section {
    flex-direction: column;
    margin-bottom: 24px;
}

/* ------------------------------------------------------------------ */
/*  Section header label                                                */
/* ------------------------------------------------------------------ */
.showcase-section__title {
    color: var(--m3-on-surface, rgb(28, 27, 31));
    margin-bottom: 8px;
}

/* ------------------------------------------------------------------ */
/*  Horizontal row of components — wraps onto next line if needed      */
/* ------------------------------------------------------------------ */
.showcase-row {
    flex-direction: row;
    flex-wrap: wrap;
}
